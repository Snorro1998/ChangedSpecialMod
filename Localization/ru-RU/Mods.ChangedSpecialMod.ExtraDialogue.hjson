Angler: {
	NPC: {
		Puro: Пуро сказал, что мне следует прекратить попытки поймать собаку-кальмара. Если это действительно слишком опасно для ребенка, я позволю ТЕБЕ поймать одну!
		Prototype: Если я брошу {NamePrototype} в воду, он убьет всех рыб током, как электрический угорь?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Не может быть! Собака-кальмар! Да, пожалуйста, останьтесь здесь ненадолго.
	}
}

BestiaryGirl: {
	NPC: {
		Puro: Я никогда раньше не видел волка такого мягкого и пушистого, как Пуро!
