DyeTrader: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Доктор К. может быть экспертом в биоинженерии, но он ничего не смыслит в моде.
	}

	Transfur: {
		BlackGoop: А! Почему черный краситель ходит?
		WhiteGoop: А! Почему белый краситель ходит?
		BlackCub: None
		WhiteCub: None
		SquidDog: Держите свои мокрые лапы подальше от моей мантии! Я не хочу, чтобы краски выцвели!
	}
}

Golfer: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Ты умеешь хранить секреты? Я случайно сломал кое-какие вещи доктора К., когда играл в гольф в его номере.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Эй, если ты когда-нибудь найдешь в воде мячи для гольфа, не мог бы ты, пожалуйста, принести их мне?
	}
}

Guide: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Если вы хотите узнать больше о слизистых монстрах, доктор К — ваш лучший выбор.
	}

	Transfur: {
		BlackGoop: Будь осторожна, маленькая слизнячка. Кто-нибудь может случайно на тебя наступить.
		WhiteGoop: Будь осторожна, маленькая слизнячка. Кто-нибудь может случайно на тебя наступить.
		BlackCub: None
		WhiteCub: None
		SquidDog: Я здесь, чтобы дать вам совет. Я рекомендую вам вернуться в воду, прежде чем у вас наступит обезвоживание.
	}
}

