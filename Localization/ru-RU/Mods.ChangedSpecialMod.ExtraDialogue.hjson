Nurse: {
	NPC: {
		Puro: Я сказал Пуро, что ему нужно съедать два апельсина в день, чтобы оставаться здоровым. Он ответил, что съедает не менее десяти в день.
		Prototype: Однажды я попросил {NamePrototype} помочь с осмотром, но он просто брызнул водой в лицо пациенту.
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Только не говорите мне, что вы сломали все руки.
	}
}

Painter: {
	NPC: {
		Puro: Можешь принести мне еще оранжевой краски? Пуро спросил, могу ли я покрасить ею всю его комнату.
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: У вас случайно нет для меня чернил? У меня закончилась чёрная краска.
	}
}

PartyGirl: {
	NPC: {
		Puro: Я обожаю тусоваться с Пуро! Он настоящий тусовщик!
		Prototype: "{NamePrototype} — настоящая машина для вечеринок. Он может одновременно воспроизводить музыку и выступать в роли диско-шара."
		Scientist: None
	}

	Transfur: {
		BlackGoop: Ух ты, шоколадный торт двигается! Вот это действительно крутой фокус для вечеринки!
		WhiteGoop: Ух ты, торт двигается! Вот это действительно крутой фокус для вечеринки!
		BlackCub: Здравствуйте! Вы пришли на вечеринку с домашними животными?
		WhiteCub: Здравствуйте! Вы пришли на вечеринку с домашними животными?
		SquidDog: Давай потанцуем! Дай мне руку! Или обе руки. Э-э, или... четыре руки?
	}
}

Pirate: {
	NPC: {
		Puro: Эй, я позабочусь о том волке-Черной Бороде, сухопутная крыса. Обожаю заботиться о морских волках!
		Prototype: None
		Scientist: Ааа, этот учёный бледный, как привидение. Кажется, он проклят.
	}

	Transfur: {
		BlackGoop: Прекрати двигаться, ты, смоляная клякса! Мне нужно, чтобы ты заделал дыру в моем корабле!
		WhiteGoop: Прекрати двигаться, ты, смоляная клякса! Мне нужно, чтобы ты заделал дыру в моем корабле!
		BlackCub: Яр, ты самый очаровательный морской щенок, которого я когда-либо видела!
		WhiteCub: Яр, ты самый очаровательный морской щенок, которого я когда-либо видела!
		SquidDog: Ага, а что же ты за морское чудовище? Собачий кракен?
	}
}

SantaClaus: {
	NPC: {
		Puro: Я могу подарить практически что угодно, но есть один человек, который внес в свой список желаний только апельсины.
		Prototype: Мои эльфы должны сделать игрушечную версию {NamePrototype}. Уверена, детям она очень понравится.
		Scientist: Я добавлю доктора К в список непослушных детей, потому что он мне не верит.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Возможно, мне стоит положить тебя в подарочную коробку и подарить тому, кто хочет щенка на Рождество.
		WhiteCub: Возможно, мне стоит положить тебя в подарочную коробку и подарить тому, кто хочет щенка на Рождество.
		SquidDog: Я не знаю, кто ты, но ты точно в списке непослушных детей!
	}
}

