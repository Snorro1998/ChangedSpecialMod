DD2Bartender: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Что случилось с доктором К.? Вчера он спросил, не хочу ли я продать его самогон, сделанный из туалетной бумаги.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: У тебя действительно так много рук? Или мне кажется, что я двоюсь из-за выпитого эля?
	}
}

Demolitionist: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Вы слышали о взрывных кроликах? Хотите, я привяжу к вам динамит, чтобы вы превратились во взрывного щенка?
		WhiteCub: Вы слышали о взрывных кроликах? Хотите, я привяжу к вам динамит, чтобы вы превратились во взрывного щенка?
		SquidDog: Прочь, чудовище! Или я достану глубинные бомбы!
	}
}

