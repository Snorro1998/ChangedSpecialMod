Angler: {
	NPC: {
		Puro: Puro powiedział, że powinienem przestać próbować złapać psa-kałamarnicę. Jeśli to naprawdę zbyt niebezpieczne dla chłopca, pozwolę ci złapać jednego!
		Prototype: Czy jeśli wrzucę {NamePrototype} do wody, porazi on wszystkie ryby prądem, jak to robi węgorz elektryczny?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Nie ma mowy! Pies-kałamarnica! Tak, proszę, zostań tu na chwilę.
	}
}

BestiaryGirl: {
	NPC: {
