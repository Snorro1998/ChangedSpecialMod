TaxCollector: {
	NPC: {
		Puro: Jeśli ten czarny wilk wkrótce nie zapłaci czynszu, to i jego obciążę podatkiem zwierzęcym!
		Prototype: Dzięki tej ogromnej mikrofalówce o nazwie {NamePrototype} rachunek za energię elektryczną wzrósł ponad dwukrotnie!
		Scientist: Doktor K twierdzi, że zapłacił czynsz, ale kwoty się nie zgadzają. Założę się, że ma doktorat z unikania płacenia podatków!
	}

	Transfur: {
		BlackGoop: Ba! Kto zapomniał wytrzeć buty? Teraz wszędzie pełno błota!
		WhiteGoop: Ba! Kto zapomniał wytrzeć buty? Teraz wszędzie pełno błota!
		BlackCub: Odejdź, kundlu! {NamePlayer} ma licencję tylko na jednego psa!
		WhiteCub: Odejdź, kundlu! {NamePlayer} ma licencję tylko na jednego psa!
		BlackCubNoLicense: Odejdź, kundlu! I nie wracaj, dopóki {NamePlayer} nie kupi licencji na psa!
		WhiteCubNoLicense: Odejdź, kundlu! I nie wracaj, dopóki {NamePlayer} nie kupi licencji na psa!
		SquidDog: Precz! Idź zawracać głowę komuś innemu, ty głupi potworze morski!
	}
}

