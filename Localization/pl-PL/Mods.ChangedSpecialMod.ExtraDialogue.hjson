Nurse: {
	NPC: {
		Puro: Powiedziałem Puro, że musi jeść dwie pomarańcze dziennie, żeby zachować zdrowie. Odpowiedział, że zjada co najmniej dziesięć dziennie.
		Prototype: Kiedyś poprosiłem {NamePrototype} o pomoc w badaniu, a on tylko spryskał twarz pacjenta wodą.
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Proszę, nie mów mi, że złamałeś wszystkie ręce.
	}
}

Painter: {
	NPC: {
		Puro: Możesz mi przynieść więcej pomarańczowej farby? Puro zapytał, czy mogę pomalować nią cały jego pokój.
