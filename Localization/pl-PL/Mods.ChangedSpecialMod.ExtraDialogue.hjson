DD2Bartender: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Co jest nie tak z Doktorem K? Wczoraj zapytał, czy chcę sprzedać jego bimber z papieru toaletowego.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
