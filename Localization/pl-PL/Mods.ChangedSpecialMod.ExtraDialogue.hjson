	}
}

Demolitionist: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Słyszałeś o wybuchowych króliczkach? Chcesz, żebym przywiązał ci dynamit, żebyś mógł być wybuchowym szczeniakiem?
		WhiteCub: Słyszałeś o wybuchowych króliczkach? Chcesz, żebym przywiązał ci dynamit, żebyś mógł być wybuchowym szczeniakiem?
