		WhiteGoop: Ach! Dlaczego ten biały barwnik chodzi?
		BlackCub: None
		WhiteCub: None
		SquidDog: Trzymaj swoje mokre łapy z daleka od mojego szlafroka! Nie chcę, żeby kolory wyblakły!
	}
}

Golfer: {
	NPC: {
