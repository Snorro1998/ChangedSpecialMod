Angler: {
	NPC: {
		Puro: Puro me dijo que dejara de intentar pescar un perro calamar. Si es demasiado peligroso para un niño, ¡te dejaré pescar uno a ti!
		Prototype: Si arrojara a {NamePrototype} al agua, ¿electrocutaría a todos los peces como una anguila eléctrica?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: ¡Imposible! ¡Un perro calamar! Sí, por favor, quédate aquí un rato.
	}
}

BestiaryGirl: {
	NPC: {
