DD2Bartender: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: ¿Qué le pasa al Doctor K? Ayer me preguntó si quería venderle su licor casero hecho con papel higiénico.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: ¿De verdad tienes tantos brazos? ¿O es que veo doble por culpa de toda esa cerveza?
	}
}

Demolitionist: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: ¿Has oído hablar de los conejos explosivos? ¿Te gustaría que te atara dinamita para que te convirtieras en un cachorro explosivo?
		WhiteCub: ¿Has oído hablar de los conejos explosivos? ¿Te gustaría que te atara dinamita para que te convirtieras en un cachorro explosivo?
		SquidDog: ¡Fuera, monstruo! ¡O sacaré las cargas de profundidad!
	}
}

