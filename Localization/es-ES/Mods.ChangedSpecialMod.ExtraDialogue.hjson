TaxCollector: {
	NPC: {
		Puro: Si ese lobo negro gelatinoso no paga el alquiler pronto, ¡también le cobraré el impuesto animal!
		Prototype: ¡Gracias a ese microondas gigante llamado {NamePrototype}, la factura de la luz se ha duplicado con creces!
		Scientist: El doctor K dice que pagó el alquiler, pero las cifras no cuadran. ¡Seguro que tiene un doctorado en evasión fiscal!
	}

	Transfur: {
		BlackGoop: ¡Bah! ¿Quién se olvidó de limpiarse los zapatos? ¡Ahora hay barro por todas partes!
		WhiteGoop: ¡Bah! ¿Quién se olvidó de limpiarse los zapatos? ¡Ahora hay barro por todas partes!
		BlackCub: ¡Vete, perro callejero! ¡{NamePlayer} solo tiene licencia para un perro!
		WhiteCub: ¡Vete, perro callejero! ¡{NamePlayer} solo tiene licencia para un perro!
		BlackCubNoLicense: ¡Vete, perro callejero! ¡Y no vuelvas hasta que {NamePlayer} haya comprado una licencia para perros!
		WhiteCubNoLicense: ¡Vete, perro callejero! ¡Y no vuelvas hasta que {NamePlayer} haya comprado una licencia para perros!
		SquidDog: ¡Fuera! ¡Vete a molestar a otra persona, estúpido monstruo marino!
	}
}

Wizard: {
	NPC: {
		Puro: No puedo dejar que Puro lea mis libros de hechizos. Ya es una bestia poderosa y no necesita además escupir fuego.
		Prototype: None
		Scientist: ¿Por qué el Doctor K intenta analizar lo que hago con la ciencia? Es simplemente... magia.
	}

	Transfur: {
		BlackGoop: ¡Un pudín de chocolate andante! ¡El hechizo mágico de los dulces funcionó!
		WhiteGoop: ¡Un pudín de leche andante! ¡El hechizo mágico de los caramelos funcionó!
		BlackCub: None
		WhiteCub: None
		SquidDog: None
	}
}
