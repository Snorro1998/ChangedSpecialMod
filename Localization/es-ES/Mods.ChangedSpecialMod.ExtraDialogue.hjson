DyeTrader: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: El Doctor K podrá ser un experto en bioingeniería, pero no sabe nada de moda.
	}

	Transfur: {
		BlackGoop: ¡AH! ¿Por qué se está moviendo el tinte negro?
		WhiteGoop: ¡AH! ¿Por qué se está moviendo el tinte blanco?
		BlackCub: None
		WhiteCub: None
		SquidDog: ¡Mantén tus patas mojadas lejos de mi bata! ¡No quiero que los colores se decoloren!
	}
}

Golfer: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: ¿Puedes guardar un secreto? Rompí accidentalmente algunas cosas del Doctor K mientras jugaba al golf en su habitación.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Oye, si alguna vez encuentras pelotas de golf en el agua, ¿podrías traérmelas, por favor?
	}
}

Guide: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Si quieres saber más sobre los monstruos de limo, el Doctor K es tu mejor opción.
	}

	Transfur: {
		BlackGoop: Ten cuidado, pequeño limo. Alguien podría pisarte sin querer.
		WhiteGoop: Ten cuidado, pequeño limo. Alguien podría pisarte sin querer.
		BlackCub: None
		WhiteCub: None
		SquidDog: Estoy aquí para darte un consejo. Te recomiendo que vuelvas a meterte en el agua antes de que te deshidrates.
	}
}

