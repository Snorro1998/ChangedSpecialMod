Nurse: {
	NPC: {
		Puro: Le dije a Puro que tenía que comer dos naranjas al día para mantenerse sano. Él me respondió que come al menos diez al día.
		Prototype: Una vez le pedí a {NamePrototype} que me ayudara con un examen, pero simplemente le roció agua en la cara al paciente.
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Por favor, no me digas que te rompiste todos los brazos.
	}
}

Painter: {
	NPC: {
		Puro: ¿Me puedes traer más pintura naranja? Puro me preguntó si podía pintar toda su habitación con ella.
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: ¿Por casualidad tienes tinta para mí? Se me acabó el negro de carbón.
	}
}

PartyGirl: {
	NPC: {
		Puro: ¡Me encanta ir de fiesta con Puro! ¡Es un auténtico fiestero!
		Prototype: "{NamePrototype} es una auténtica máquina de fiestas. Puede reproducir música y funcionar como una bola de discoteca al mismo tiempo."
		Scientist: None
	}

	Transfur: {
		BlackGoop: ¡Guau, el pastel de chocolate se mueve! ¡Eso sí que es un truco genial para fiestas!
		WhiteGoop: ¡Guau, el pastel se mueve! ¡Eso sí que es un truco genial para fiestas!
		BlackCub: ¡Hola! ¿Viniste a la fiesta de mascotas?
		WhiteCub: ¡Hola! ¿Viniste a la fiesta de mascotas?
		SquidDog: ¡Bailemos! ¡Dame la mano! O las dos. Eh, o... ¿las cuatro?
	}
}

Pirate: {
	NPC: {
		Puro: ¡Ahoy! Yo tomo a ese lobo de Barbanegra bajo mi protección, marinero de agua dulce. ¡Me encanta criar cachorros marinos!
		Prototype: None
		Scientist: ¡Arrr! Ese científico está pálido como un fantasma. Creo que está maldito.
	}

	Transfur: {
		BlackGoop: ¡Quédate quieto, pedazo de alquitrán! ¡Necesito que arregles el agujero de mi barco!
		WhiteGoop: ¡Quédate quieto, pedazo de alquitrán! ¡Necesito que arregles el agujero de mi barco!
		BlackCub: ¡Yar, eres el cachorro marino más adorable que jamás haya visto!
		WhiteCub: ¡Yar, eres el cachorro marino más adorable que jamás haya visto!
		SquidDog: ¡Arrr! ¿Qué monstruo marino eres? ¿Un kraken canino?
	}
}

SantaClaus: {
	NPC: {
		Puro: Puedo regalar casi cualquier cosa, y luego está esa persona que solo ha puesto naranjas en su lista de deseos.
		Prototype: Mis elfos deberían hacer una versión de juguete del {NamePrototype}. Estoy seguro de que a los niños les encantará.
		Scientist: Voy a añadir al Doctor K a la lista de los traviesos, porque no cree en mí.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Tal vez debería meterte dentro de un regalo y dárselo a alguien que quiera un cachorro para Navidad.
		WhiteCub: Tal vez debería meterte dentro de un regalo y dárselo a alguien que quiera un cachorro para Navidad.
		SquidDog: No sé quién eres, ¡pero sin duda estás en la lista de los traviesos!
	}
}

