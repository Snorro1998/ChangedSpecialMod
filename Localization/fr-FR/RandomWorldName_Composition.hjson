	DrK4: "{Location} de Dr. K"
	Oranges1: La {Adjective} {Location} des Oranges
	Oranges2: "{Adjective} {Location} des Oranges"
	Oranges3: La {Location} des Oranges
	Oranges4: "{Location} des Oranges"
	Puro1: La {Adjective} {Location} de Puro
	Puro2: "{Adjective} {Location} de Puro"
	Puro3: La {Location} de Puro
	Puro4: "{Location} de Puro"
	SquidDog1: La {Adjective} {Location} de Chien-calamar
	SquidDog2: "{Adjective} {Location} de Chien-calamar"
	SquidDog3: La {Location} de Chien-calamar
	SquidDog4: "{Location} de Chien-calamar"
	TigerShark1: La {Adjective} {Location} de Requin-tigre
