Angler: {
	NPC: {
		Puro: Puro m'a dit d'arrêter d'essayer d'attraper un chien-calamar. Si c'est vraiment trop dangereux pour un enfant, je te laisserai en attraper un!
		Prototype: Si je jetais {NamePrototype} dans l'eau, électrocuterait-il tous les poissons comme une anguille électrique ?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Impossible! Un chien-calamar! Oui, restez ici un moment, s'il vous plaît.
	}
}

BestiaryGirl: {
