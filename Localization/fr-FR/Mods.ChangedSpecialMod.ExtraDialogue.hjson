		Puro: None
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: C'est une touffe de cheveux qui marche? Beurk!
		WhiteGoop: C'est une touffe de cheveux qui marche? Beurk!
		BlackCub: Désolé, je ne peux pas vous aider. Ce n'est pas un salon de coiffure pour chiens.
		WhiteCub: Désolé, je ne peux pas vous aider. Ce n'est pas un salon de coiffure pour chiens.
		SquidDog: Désolé, je ne peux pas vous aider. Ce n'est pas un salon de coiffure pour chiens.
	}
}

TaxCollector: {
	NPC: {
		Puro: Si ce loup en gelée noire ne paie pas son loyer bientôt, je lui ferai payer la taxe animale aussi!
		Prototype: Grâce à ce micro-ondes surdimensionné appelé {NamePrototype}, la facture d'énergie a plus que doublé!
		Scientist: Le docteur K. affirme avoir payé le loyer, mais les chiffres ne correspondent pas. Je parie qu'il est docteur en fraude fiscale!
	}

	Transfur: {
		BlackGoop: Beurk! Qui a oublié d'essuyer ses chaussures? Maintenant, il y a de la boue partout!
		WhiteGoop: Beurk! Qui a oublié d'essuyer ses chaussures? Maintenant, il y a de la boue partout!
		BlackCub: Va-t'en, cabot! {NamePlayer} n'a de permis que pour un seul chien!
		WhiteCub: Va-t'en, cabot! {NamePlayer} n'a de permis que pour un seul chien!
		BlackCubNoLicense: Va-t'en, cabot! Et ne reviens pas tant que {NamePlayer} n'aura pas acheté de permis pour chien!
		WhiteCubNoLicense: Va-t'en, cabot! Et ne reviens pas tant que {NamePlayer} n'aura pas acheté de permis pour chien!
		SquidDog: Dégage! Va embêter quelqu'un d'autre, espèce de monstre marin stupide!
	}
}

Wizard: {
	NPC: {
		Puro: Je ne peux pas laisser Puro lire mes grimoires. C'est déjà une bête redoutable et il n'a pas besoin de cracher du feu en plus.
		Prototype: None
		Scientist: Pourquoi le docteur K essaie-t-il d'analyser ce que je fais avec la science? C'est tout simplement... magique.
	}

	Transfur: {
		BlackGoop: Un pudding au chocolat ambulant! La sortilège magique de bonbons a fonctionné!
		WhiteGoop: Un pudding au lait ambulant! La sortilège magique de bonbons a fonctionné!
		BlackCub: None
		WhiteCub: None
		SquidDog: None
	}
}
