DyeTrader: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Le docteur K est peut-être un expert en bio-ingénierie, mais il ne connaît rien à la mode.
	}

	Transfur: {
		BlackGoop: AH! Pourquoi la teinture noire se met-elle à marcher?
		WhiteGoop: AH! Pourquoi la teinture blanche se met-elle à marcher?
		BlackCub: None
		WhiteCub: None
		SquidDog: Éloignez vos pattes mouillées de ma robe! Je ne veux pas que les couleurs déteignent!
	}
}

Golfer: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Sais-tu garder un secret? J'ai cassé par inadvertance des affaires du docteur K pendant que je jouais au golf dans sa chambre.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Hé, si jamais tu trouves des balles de golf dans l'eau, pourrais-tu me les rapporter, s'il te plaît?
	}
}

Guide: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Si vous souhaitez en savoir plus sur les monstres des gelée, le docteur K est la personne qu'il vous faut.
	}

	Transfur: {
		BlackGoop: Fais attention, petite gluante. Quelqu'un pourrait te marcher dessus par inadvertance.
		WhiteGoop: Fais attention, petite gluante. Quelqu'un pourrait te marcher dessus par inadvertance.
		BlackCub: None
		WhiteCub: None
		SquidDog: Je suis là pour vous donner un conseil. Je vous recommande de retourner à l'eau avant d'être déshydraté.
	}
}

Mechanic: {
	NPC: {
		Puro: None
		Prototype: Quoi? {NamePrototype} se comporte encore bizarrement? Avez-vous essayé de l’éteindre et de le rallumer?
		Scientist: None
	}

	Transfur: {
		BlackGoop: Une flaque? Ne me dites pas qu'une des pompes est encore tombée en panne.
		WhiteGoop: Une flaque? Ne me dites pas qu'une des pompes est encore tombée en panne.
		BlackCub: None
		WhiteCub: None
		SquidDog: None
	}
}

Nurse: {
	NPC: {
		Puro: J'ai dit à Puro qu'il devait manger deux oranges par jour pour rester en bonne santé. Il m'a répondu qu'il en mangeait au moins dix par jour.
		Prototype: Une fois, j'ai demandé à {NamePrototype} de m'aider pour un examen, mais il s'est contenté de vaporiser de l'eau au visage du patient.
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Ne me dites pas que vous vous êtes cassé tous les bras.
	}
}

Painter: {
	NPC: {
		Puro: Peux-tu m'apporter plus de peinture orange? Puro m'a demandé si je pouvais peindre toute sa chambre avec.
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Auriez-vous de l'encre pour moi par hasard? Je n'ai plus de noir de carbone.
	}
}

PartyGirl: {
	NPC: {
		Puro: J'adore faire la fête avec Puro! C'est un vrai fêtard!
		Prototype: "{NamePrototype} est une véritable machine à faire la fête. Il peut jouer de la musique et servir de boule à facettes en même temps."
		Scientist: None
	}

	Transfur: {
		BlackGoop: Waouh, le gâteau au chocolat bouge! Voilà un tour de magie impressionnant!
		WhiteGoop: Waouh, le gâteau bouge! Voilà un tour de magie impressionnant!
		BlackCub: Bonjour ! Vous êtes là pour la fête des animaux?
		WhiteCub: Bonjour ! Vous êtes là pour la fête des animaux?
		SquidDog: Dansons! Donne-moi ta main! Ou les deux mains. Euh, ou... les quatre mains?
	}
}

Pirate: {
	NPC: {
		Puro: Ahoy! Je vais m'occuper de ce loup à barbe noire, terrien! J'adore élever des chiens de mer!
		Prototype: None
		Scientist: Arrr, ce scientifique a l'air aussi pâle qu'un fantôme. Je crois qu'il est maudit.
	}

	Transfur: {
		BlackGoop: Restez immobile, espèce de tas de goudron! J'ai besoin que tu répares le trou dans mon navire!
		WhiteGoop: Restez immobile, espèce de tas de goudron! J'ai besoin que tu répares le trou dans mon navire!
		BlackCub: Yar, tu es le plus adorable chiot de mer que j'aie jamais vu!
		WhiteCub: Yar, tu es le plus adorable chiot de mer que j'aie jamais vu!
		SquidDog: Arr, quel monstre marin es-tu donc? Un kraken canin?
	}
}

SantaClaus: {
	NPC: {
		Puro: Je peux offrir presque n'importe quoi en cadeau, et puis il y a toujours cette personne qui n'a mis que des oranges sur sa liste de souhaits.
		Prototype: Mes lutins devraient fabriquer une version jouet de {NamePrototype}. Je suis sûr que les enfants l'adoreraient.
		Scientist: J'ajouterai le docteur K à la liste des vilains, car il ne croit pas en moi.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Peut-être devrais-je te mettre dans une boîte cadeau et t'offrir à quelqu'un qui veut un chiot pour Noël.
		WhiteCub: Peut-être devrais-je te mettre dans une boîte cadeau et t'offrir à quelqu'un qui veut un chiot pour Noël.
		SquidDog: Je ne sais pas qui vous êtes, mais vous êtes assurément sur la liste des vilains!
	}
}

Stylist: {
