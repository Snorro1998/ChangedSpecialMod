DD2Bartender: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: Qu'est-ce qui ne va pas avec le docteur K? Hier, il m'a demandé si je voulais vendre son alcool de contrebande fabriqué à partir de papier toilette.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Tu as vraiment autant de bras? Ou alors je vois double à cause de toute cette bière?
	}
}

Demolitionist: {
	NPC: {
		Puro: None
		Prototype: None
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: As-tu déjà entendu parler de lapins explosifs? Veux-tu que je t’attache de la dynamite pour que tu deviennes un chiot explosif?
		WhiteCub: As-tu déjà entendu parler de lapins explosifs? Veux-tu que je t’attache de la dynamite pour que tu deviennes un chiot explosif?
		SquidDog: Disparais, monstre! Ou je sors les grenades sous-marines!
	}
}

