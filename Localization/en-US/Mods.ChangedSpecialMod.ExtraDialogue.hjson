Angler: {
	NPC: {
		Puro: Puro said I should stop trying to catch a Squid Dog. If it's really too dangerous for a kid, I'll let YOU catch one!
		Prototype: If I threw {NamePrototype} in the water, would he electrocute all the fish like an electric eel?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: No way! A Squid Dog! Yes, please stay here for a while.
	}
}

