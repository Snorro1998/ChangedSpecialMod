Angler: {
	NPC: {
		Puro: Puro ha detto che dovrei smetterla di cercare di catturare un cane-calamaro. Se è davvero troppo pericoloso per un bambino, lascerò che lo catturi TU!
		Prototype: Se gettassi {NamePrototype} in acqua, folgorerebbe tutti i pesci come un'anguilla elettrica?
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Non ci credo! Un Cane-calamaro! Sì, per favore, resta qui ancora un po'.
	}
}

