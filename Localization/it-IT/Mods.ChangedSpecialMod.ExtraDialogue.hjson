TaxCollector: {
	NPC: {
		Puro: Se quel lupo nero gelatinoso non paga presto l'affitto, gli addebiterò anche la tassa sugli animali!
		Prototype: Grazie a quel forno a microonde sovradimensionato chiamato {NamePrototype} la bolletta energetica è più che raddoppiata!
		Scientist: Il dottor K ha detto di aver pagato l'affitto, ma i conti non tornano. Scommetto che ha un dottorato in evasione fiscale!
	}

	Transfur: {
		BlackGoop: Bah! Chi si è dimenticato di pulire le scarpe? Ora c'è fango dappertutto!
		WhiteGoop: Bah! Chi si è dimenticato di pulire le scarpe? Ora c'è fango dappertutto!
		BlackCub: Vattene, bastardo! {NamePlayer} ha la licenza solo per un cane!
		WhiteCub: Vattene, bastardo! {NamePlayer} ha la licenza solo per un cane!
		BlackCubNoLicense: Vattene, bastardo! E non tornare finché {NamePlayer} non avrà comprato la licenza per cani!
		WhiteCubNoLicense: Vattene, bastardo! E non tornare finché {NamePlayer} non avrà comprato la licenza per cani!
		SquidDog: Via! Vai a dare fastidio a qualcun altro, stupido mostro marino!
	}
}

Wizard: {
	NPC: {
		Puro: Non posso permettere a Puro di leggere i miei libri di incantesimi. È già una bestia potentissima e non ha bisogno di sputare fuoco anche.
		Prototype: None
		Scientist: Perché il dottor K cerca di analizzare scientificamente quello che sto facendo? È semplicemente... magia.
	}

	Transfur: {
		BlackGoop: Un budino di cioccolato ambulante! L'incantesimo magico delle caramelle ha funzionato!
		WhiteGoop: Un budino di latte ambulante! L'incantesimo magico delle caramelle ha funzionato!
		BlackCub: None
		WhiteCub: None
		SquidDog: None
	}
}
