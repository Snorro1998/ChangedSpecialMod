PartyGirl: {
	NPC: {
		Puro: Adoro fare festa con Puro! È un vero animale da festa!
		Prototype: "{NamePrototype} è una vera macchina da festa. Può riprodurre musica e fungere da palla da discoteca allo stesso tempo."
		Scientist: None
	}

	Transfur: {
		BlackGoop: Wow, la torta al cioccolato si muove! Questo sì che è un trucco da festa fantastico!
		WhiteGoop: Wow, la torta si muove! Questo sì che è un trucco da festa fantastico!
		BlackCub: Ciao! Sei qui per la festa degli animali domestici?
		WhiteCub: Ciao! Sei qui per la festa degli animali domestici?
		SquidDog: Balliamo! Dammi la mano! O entrambe le mani. Ehm, o... quattro mani?
	}
}

Pirate: {
	NPC: {
		Puro: Ehi, mi prenderò cura di quel lupo dalla barba nera, marinaio di terraferma. Adoro prendermi cura dei lupi di mare!
		Prototype: None
		Scientist: Arrr, quello scienziato è pallido come un fantasma. Credo sia maledetto.
	}

	Transfur: {
		BlackGoop: Smettila di muoverti, macchia di catrame! Devi riparare il buco nella mia nave!
		WhiteGoop: Smettila di muoverti, macchia di catrame! Devi riparare il buco nella mia nave!
		BlackCub: Yar, sei il cucciolo di mare più adorabile che abbia mai visto!
		WhiteCub: Yar, sei il cucciolo di mare più adorabile che abbia mai visto!
		SquidDog: Arrr, che mostro marino sei allora? Un kraken canino?
	}
}

SantaClaus: {
	NPC: {
		Puro: Posso regalare quasi qualsiasi cosa, e poi c'è quella persona che ha messo solo arance nella sua lista dei desideri.
		Prototype: I miei elfi dovrebbero creare una versione giocattolo di {NamePrototype}. Sono sicuro che i bambini la adoreranno.
		Scientist: Aggiungerò il dottor K alla lista dei cattivi, perché non crede in me.
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: Forse dovrei metterti in una confezione regalo e darti a qualcuno che desidera un cucciolo per Natale.
		WhiteCub: Forse dovrei metterti in una confezione regalo e darti a qualcuno che desidera un cucciolo per Natale.
		SquidDog: Non so chi tu sia, ma sei sicuramente nella lista dei cattivi!
	}
}

