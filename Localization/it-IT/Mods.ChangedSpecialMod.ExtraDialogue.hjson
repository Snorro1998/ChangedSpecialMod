Nurse: {
	NPC: {
		Puro: Ho detto a Puro che per rimanere in salute doveva mangiare due arance al giorno. Lui ha risposto che ne mangia almeno dieci al giorno.
		Prototype: Una volta ho chiesto aiuto a {NamePrototype} per un esame, ma lui ha semplicemente spruzzato acqua in faccia al paziente.
		Scientist: None
	}

	Transfur: {
		BlackGoop: None
		WhiteGoop: None
		BlackCub: None
		WhiteCub: None
		SquidDog: Per favore, non dirmi che ti sei rotto tutte le braccia.
	}
}

